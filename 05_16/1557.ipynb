   "source": [
    "# 學生總分為300\n",
    "#有些可以加5%\n",
    "\n",
    "while True:\n",
    "    try:\n",
    "        scores = int(input('輸入分數'))\n",
    "        break\n",
    "    except ValueError:\n",
    "        print(\"請輸入有效的整數。\")\n",
    "\n",
    "is_add = input('是否符合加分條件?(y/n)')\n",
    "\n",
    "if is_add == 'y':\n",
    "    scores = scores * 1.05\n",
    "\n",
    "scores = int (scores+0.5)\n",
    "\n",
    "print('總分:', scores)\n"
   ]
  }
